{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Run",
  "description": "Canonical run record for Control Center timeline views.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "timestamp",
    "chain",
    "block",
    "status",
    "security_score"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "chain": { "type": "string", "minLength": 1 },
    "block": { "type": "integer", "minimum": 0 },
    "status": { "type": "string", "enum": ["passed", "failed", "partial", "skipped"] },
    "security_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "proof_count": { "type": "integer", "minimum": 0 },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "log_path": { "type": "string" }
  },
  "additionalProperties": false
}
