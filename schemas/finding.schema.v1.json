{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding",
  "description": "Normalized finding record for explorer and detail pages.",
  "type": "object",
  "required": [
    "schema_version",
    "finding_id",
    "content_hash",
    "run_id",
    "title",
    "severity",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "finding_id": { "type": "string", "minLength": 1 },
    "content_hash": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "status": { "type": "string", "enum": ["new", "triaged", "regressed", "resolved", "dismissed", "needs_review"] },
    "impact_usd": { "type": "number" },
    "protocol": { "type": "string" },
    "chain": { "type": "string" },
    "block_number": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
